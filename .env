# Entorno
NODE_ENV=development
PORT=3000

# Base de datos PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sga_db?schema=public"

# JWT RS256 (puedes generar claves temporales para desarrollo)
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
MIIEpAIBAAKCAQEA...
-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8A...
-----END PUBLIC KEY-----"

# Expiración de tokens
ACCESS_TOKEN_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7

# Redis (si tienes Redis local)
REDIS_URL="redis://localhost:6379"

# CORS
CORS_ORIGINS="*"

# Logs
LOG_LEVEL=info

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Máximo de actividades por página
MAX_ACTIVITIES_PER_PAGE=100