{
    "name": "sga-backend",
    "version": "1.0.0",
    "description": "Sistema de Gestión Agroindustrial - Backend",
    "main": "dist/main.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
        "build": "tsc",
        "start": "node dist/main.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "migrate": "prisma migrate dev",
        "migrate:prod": "prisma migrate deploy",
        "seed": "ts-node prisma/seed.ts",
        "generate": "prisma generate",
        "lint": "eslint src --ext .ts",
        "format": "prettier --write 'src/**/*.ts'"
    },
    "dependencies": {
        "@fastify/cors": "^9.0.1",
        "@fastify/helmet": "^11.1.1",
        "@fastify/rate-limit": "^9.1.0",
        "@fastify/swagger": "^8.14.0",
        "@fastify/swagger-ui": "^3.0.0",
        "@prisma/client": "^5.11.0",
        "bcrypt": "^5.1.1",
        "dotenv": "^16.4.5",
        "fastify": "^4.26.2",
        "ioredis": "^5.3.2",
        "jsonwebtoken": "^9.0.2",
        "pino": "^8.19.0",
        "pino-pretty": "^11.0.0",
        "reflect-metadata": "^0.2.1",
        "tsyringe": "^4.8.0",
        "uuid": "^9.0.1",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.2",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/node": "^20.11.19",
        "@types/supertest": "^6.0.2",
        "@types/uuid": "^9.0.8",
        "eslint": "^8.57.0",
        "prisma": "^5.11.0",
        "supertest": "^6.3.4",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.4.2",
        "vitest": "^1.3.1",
        "@vitest/coverage-v8": "^1.3.1"
    }
}